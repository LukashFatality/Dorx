        results = []
        queries = self.cfg.get('database_files', [])
        
        for i, dork in enumerate(queries, 1):
            query = f"site:.{tld} {dork}"
            print(f"[{i}/{len(queries)}] {dork[:50]}...")
            urls = self.search(query, max_pages=1)
            for url in urls:
                status, final = self.check_status(url)
                if status == 200:
                    print(f"[DB] {final}")
                    results.append({'url': final, 'type': 'database', 'status': status})
                    if download_all:
                        path, size = self.download_file(final)
                        if path:
                            print(f"  [DOWNLOADED] {path} ({size} bytes)")
            time.sleep(1)
        self.results.extend(results)
        return results

